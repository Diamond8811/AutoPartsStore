<UserControl x:Class="AutoPartsStore.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Панель аналитики"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <WrapPanel Grid.Column="1"
                           VerticalAlignment="Center">

                    <ComboBox Width="150"
                              SelectedValue="{Binding SelectedPeriod}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="За месяц" Tag="month"/>
                        <ComboBoxItem Content="За квартал" Tag="quarter"/>
                        <ComboBoxItem Content="За год" Tag="year"/>
                        <ComboBoxItem Content="Свои даты" Tag="custom"/>
                    </ComboBox>

                    <DatePicker SelectedDate="{Binding CustomDateFrom}"
                                IsEnabled="{Binding IsCustomPeriod}"
                                Width="120"/>

                    <DatePicker SelectedDate="{Binding CustomDateTo}"
                                IsEnabled="{Binding IsCustomPeriod}"
                                Width="120"/>

                    <Button Content="Применить"
                            Command="{Binding ApplyCustomPeriodCommand}"
                            IsEnabled="{Binding IsCustomPeriod}"/>
                </WrapPanel>
            </Grid>

            <WrapPanel>

                <Border Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18"
                        Margin="10"
                        Width="240">
                    <StackPanel>
                        <TextBlock Text="Товаров на складе"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalProducts}"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18"
                        Margin="10"
                        Width="240">
                    <StackPanel>
                        <TextBlock Text="Доход за период"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding PeriodRevenue, StringFormat={}{0:N2} ₽}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18"
                        Margin="10"
                        Width="240">
                    <StackPanel>
                        <TextBlock Text="Заказов за период"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding PeriodOrdersCount}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18"
                        Margin="10"
                        Width="240">
                    <StackPanel>
                        <TextBlock Text="Возвраты за период"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding PeriodReturnsSum, StringFormat={}{0:N2} ₽}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource SecondaryBrush}"/>
                    </StackPanel>
                </Border>

            </WrapPanel>

            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderColorBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,30,0,0">

                <StackPanel>

                    <TextBlock Text="Доход по дням"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <lvc:CartesianChart Series="{Binding RevenueDailySeries}"
                                        LegendLocation="Right"
                                        Height="320">

                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Labels="{Binding RevenueDailyLabels}"
                                      LabelsRotation="45"/>
                        </lvc:CartesianChart.AxisX>

                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis LabelFormatter="{Binding CurrencyFormatter}"/>
                        </lvc:CartesianChart.AxisY>

                    </lvc:CartesianChart>

                </StackPanel>
            </Border>

            <Grid Margin="0,30,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="20"
                        Margin="10">

                    <StackPanel>

                        <TextBlock Text="Заказы по дням недели"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <lvc:CartesianChart Series="{Binding OrdersByWeekdaySeries}"
                                            Height="280">

                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding Weekdays}"/>
                            </lvc:CartesianChart.AxisX>

                        </lvc:CartesianChart>

                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="20"
                        Margin="10">

                    <StackPanel>

                        <TextBlock Text="Возвраты по причинам"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <lvc:PieChart Series="{Binding ReturnsByReasonSeries}"
                                      LegendLocation="Right"
                                      Height="280"/>

                    </StackPanel>
                </Border>

            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>