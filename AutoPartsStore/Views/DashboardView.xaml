<UserControl x:Class="AutoPartsStore.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">
    <UserControl.Resources>
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChartCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <!-- Панель выбора периода -->
            <Border Style="{StaticResource ChartCard}" Margin="0,0,0,10">
                <WrapPanel HorizontalAlignment="Right">
                    <TextBlock Text="Период:" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <ComboBox SelectedValue="{Binding SelectedPeriod}" SelectedValuePath="Tag" Width="140" Margin="5">
                        <ComboBoxItem Content="За месяц" Tag="month" IsSelected="True"/>
                        <ComboBoxItem Content="За квартал" Tag="quarter"/>
                        <ComboBoxItem Content="За год" Tag="year"/>
                        <ComboBoxItem Content="Свои даты" Tag="custom"/>
                    </ComboBox>
                    <TextBlock Text="с:" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <DatePicker SelectedDate="{Binding CustomDateFrom}" Margin="5"
                                IsEnabled="{Binding SelectedPeriod, Converter={StaticResource EqualsConverter}, ConverterParameter='custom'}"/>
                    <TextBlock Text="по:" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <DatePicker SelectedDate="{Binding CustomDateTo}" Margin="5"
                                IsEnabled="{Binding SelectedPeriod, Converter={StaticResource EqualsConverter}, ConverterParameter='custom'}"/>
                    <Button Content="Применить" Command="{Binding ApplyCustomPeriodCommand}" Margin="5"
                            IsEnabled="{Binding SelectedPeriod, Converter={StaticResource EqualsConverter}, ConverterParameter='custom'}"/>
                </WrapPanel>
            </Border>


            <!-- Карточки KPI -->
            <WrapPanel>
                <Border Style="{StaticResource KpiCard}" Width="220">
                    <StackPanel>
                        <TextBlock Text="Товаров на складе" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalProducts}" FontSize="28" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}" Width="220">
                    <StackPanel>
                        <TextBlock Text="Доход за период" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding MonthRevenue, StringFormat={}{0:N2} руб.}" FontSize="28" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}" Width="220">
                    <StackPanel>
                        <TextBlock Text="Заказов сегодня" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TodayOrdersCount}" FontSize="28" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}" Width="220">
                    <StackPanel>
                        <TextBlock Text="Возвратов за период" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding MonthReturnsSum, StringFormat={}{0:N2} руб.}" FontSize="28" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- График 1: Доход по дням -->
            <Border Style="{StaticResource ChartCard}" Margin="0,15,0,0">
                <StackPanel>
                    <TextBlock Text="📈 Доход по дням" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <lvc:CartesianChart Series="{Binding RevenueDailySeries}" Height="300" LegendLocation="Right"/>
                </StackPanel>
            </Border>

            <!-- Графики 2 и 3 -->
            <WrapPanel Margin="0,15,0,0">
                <Border Style="{StaticResource ChartCard}" Width="1.5" Margin="5,0,5,0">
                    <StackPanel>
                        <TextBlock Text="📊 Заказы по дням недели" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <lvc:CartesianChart Series="{Binding OrdersByWeekdaySeries}" Height="280">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding Weekdays}" Title="День недели"/>
                            </lvc:CartesianChart.AxisX>
                        </lvc:CartesianChart>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource ChartCard}" Width="1" Margin="5,0,5,0">
                    <StackPanel>
                        <TextBlock Text="🥧 Возвраты по причинам" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <lvc:PieChart Series="{Binding ReturnsByReasonSeries}" Height="280" LegendLocation="Right"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <ProgressBar IsIndeterminate="{Binding IsBusy}" Width="200" Height="10"
                         HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>