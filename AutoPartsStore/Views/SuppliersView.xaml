<UserControl x:Class="AutoPartsStore.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кнопки -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Добавить"
                    Command="{Binding AddCommand}"/>

            <Button Content="Удалить"
                    Command="{Binding DeleteCommand}"
                    Style="{StaticResource DangerButton}"/>
        </WrapPanel>

        <!-- Таблица -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Suppliers}"
                  SelectedItem="{Binding SelectedSupplier}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Название"
                                    Binding="{Binding Name}"
                                    Width="200"/>

                <DataGridTextColumn Header="Контактное лицо"
                                    Binding="{Binding ContactPerson}"
                                    Width="200"/>

                <DataGridTextColumn Header="Телефон"
                                    Binding="{Binding Phone}"
                                    Width="150"/>

                <DataGridTextColumn Header="Email"
                                    Binding="{Binding Email}"
                                    Width="200"/>
            </DataGrid.Columns>

        </DataGrid>

        <!-- Панель редактирования -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBackgroundBrush}"
                Padding="15"
                CornerRadius="8"
                Margin="0,10,0,0"
                Visibility="{Binding SelectedSupplier, Converter={StaticResource ObjectToVisibilityConverter}}">

            <StackPanel>

                <TextBlock Text="Редактирование поставщика"
                           FontWeight="Bold"
                           FontSize="14"
                           Margin="0,0,0,10"/>

                <WrapPanel>

                    <TextBlock Text="Название:"
                               VerticalAlignment="Center"
                               Margin="5"/>

                    <TextBox Text="{Binding SelectedSupplier.Name, UpdateSourceTrigger=PropertyChanged}"
                             Width="200"/>

                    <TextBlock Text="Контактное лицо:"
                               VerticalAlignment="Center"
                               Margin="5"/>

                    <TextBox Text="{Binding SelectedSupplier.ContactPerson, UpdateSourceTrigger=PropertyChanged}"
                             Width="200"/>

                    <TextBlock Text="Телефон:"
                               VerticalAlignment="Center"
                               Margin="5"/>

                    <TextBox Text="{Binding SelectedSupplier.Phone, UpdateSourceTrigger=PropertyChanged}"
                             Width="150"/>

                    <TextBlock Text="Email:"
                               VerticalAlignment="Center"
                               Margin="5"/>

                    <TextBox Text="{Binding SelectedSupplier.Email, UpdateSourceTrigger=PropertyChanged}"
                             Width="200"/>

                </WrapPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">

                    <Button Content="Сохранить изменения"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource AccentButton}"/>

                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>
</UserControl>