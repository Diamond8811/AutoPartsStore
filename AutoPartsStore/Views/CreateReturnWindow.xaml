<Window x:Class="AutoPartsStore.Views.CreateReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание возврата" Height="600" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" Padding="10" CornerRadius="8" Margin="0,0,0,10">
            <WrapPanel>
                <TextBlock Text="Заказ:" VerticalAlignment="Center" Margin="5,0,2,0"/>
                <ComboBox ItemsSource="{Binding Orders}" DisplayMemberPath="OrderId"
                          SelectedItem="{Binding SelectedOrder}" Width="150" Margin="5"/>
                <Button Content="Загрузить товары" Command="{Binding LoadOrderItemsCommand}" Margin="5"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" Padding="10" CornerRadius="8" Margin="0,0,0,10">
            <WrapPanel>
                <TextBlock Text="Причина:" VerticalAlignment="Center" Margin="5,0,2,0"/>
                <ComboBox ItemsSource="{Binding Reasons}" DisplayMemberPath="Reason"
                          SelectedItem="{Binding SelectedReason}" Width="250" Margin="5"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource CardBackgroundBrush}" Padding="10" CornerRadius="8" Margin="0,0,0,10">
            <WrapPanel>
                <TextBlock Text="Товар:" VerticalAlignment="Center" Margin="5,0,2,0"/>
                <ComboBox ItemsSource="{Binding OrderItems}" DisplayMemberPath="Products.Name"
                          SelectedItem="{Binding SelectedOrderItem}" Width="300" Margin="5"/>
                <TextBlock Text="Кол-во:" VerticalAlignment="Center" Margin="5,0,2,0"/>
                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="5"/>
                <Button Content="➕ Добавить" Command="{Binding AddToCartCommand}" Margin="5"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="3" ItemsSource="{Binding ReturnCart}" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Товар" Binding="{Binding OrderItem.Products.Name}" Width="*"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="💾 Оформить возврат" Command="{Binding SaveCommand}" Margin="5"/>
            <Button Content="❌ Отмена" Click="Close" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>