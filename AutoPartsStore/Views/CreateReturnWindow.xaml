<Window x:Class="AutoPartsStore.Views.CreateReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание возврата"
        Height="650"
        Width="850"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Выбор заказа"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="Заказ:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <ComboBox ItemsSource="{Binding Orders}"
                              DisplayMemberPath="OrderId"
                              SelectedItem="{Binding SelectedOrder}"
                              Width="150"/>

                    <Button Content="Загрузить товары"
                            Command="{Binding LoadOrderItemsCommand}"
                            Style="{StaticResource AccentButton}"
                            Margin="20,0,0,0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Причина возврата"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <ComboBox ItemsSource="{Binding Reasons}"
                          DisplayMemberPath="Reason"
                          SelectedItem="{Binding SelectedReason}"
                          Width="300"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Добавление позиции"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="Товар:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <ComboBox ItemsSource="{Binding OrderItems}"
                              DisplayMemberPath="Products.Name"
                              SelectedItem="{Binding SelectedOrderItem}"
                              Width="300"/>

                    <TextBlock Text="Количество:"
                               VerticalAlignment="Center"
                               Margin="20,0,10,0"/>

                    <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                             Width="70"/>

                    <Button Content="Добавить"
                            Command="{Binding AddToCartCommand}"
                            Style="{StaticResource AccentButton}"
                            Margin="20,0,0,0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Состав возврата"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <DataGrid ItemsSource="{Binding ReturnCart}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F5F7FA">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EEF2F5"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#D6EAF8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Товар"
                                            Binding="{Binding OrderItem.Products.Name}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Количество"
                                            Binding="{Binding Quantity}"
                                            Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Content="Оформить возврат"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource AccentButton}"
                    Margin="5"/>

            <Button Content="Отмена"
                    Click="Close"
                    Style="{StaticResource DangerButton}"
                    Margin="5"/>

        </StackPanel>

    </Grid>
</Window>