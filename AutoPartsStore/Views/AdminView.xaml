<UserControl x:Class="AutoPartsStore.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Добавить пользователя"
            Command="{Binding AddUserCommand}"/>
            <Button Content="Удалить"
            Command="{Binding DeleteUserCommand}"
            Style="{StaticResource DangerButton}"/>
            <Button Content="Заблокировать / Разблокировать"
            Command="{Binding ToggleBlockCommand}"/>
            <Button Content="Сбросить пароль"
            Command="{Binding ResetPasswordCommand}"/>
            <Button Content="Сгенерировать пароль"
            Command="{Binding GeneratePasswordCommand}"/>
        </WrapPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Users}"
                  SelectedItem="{Binding SelectedUser}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Логин"
                                    Binding="{Binding Login}"
                                    Width="150"/>
                <DataGridTextColumn Header="ФИО"
                                    Binding="{Binding FullName}"
                                    Width="200"/>
                <DataGridTextColumn Header="Роль"
                                    Binding="{Binding Roles.Name}"
                                    Width="150"/>
                <DataGridCheckBoxColumn Header="Активен"
                                        Binding="{Binding IsActive}"
                                        Width="100"/>
            </DataGrid.Columns>

        </DataGrid>

        <Border Grid.Row="2"
                Background="{StaticResource CardBackgroundBrush}"
                Padding="15"
                CornerRadius="8"
                Margin="0,10,0,0"
                Visibility="{Binding SelectedUser, Converter={StaticResource ObjectToVisibilityConverter}}">

            <StackPanel>

                <TextBlock Text="Редактирование пользователя"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <WrapPanel>

                    <TextBlock Text="Логин:" Margin="5" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SelectedUser.Login, UpdateSourceTrigger=PropertyChanged}"
                             Width="150"/>

                    <TextBlock Text="ФИО:" Margin="5" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SelectedUser.FullName, UpdateSourceTrigger=PropertyChanged}"
                             Width="200"/>

                    <TextBlock Text="Роль:" Margin="5" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding Roles}"
                              SelectedItem="{Binding SelectedUser.Roles}"
                              Width="150"/>

                </WrapPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">

                    <Button Content="Сохранить изменения"
                            Command="{Binding SaveUserCommand}"
                            Style="{StaticResource AccentButton}"/>

                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>