<UserControl x:Class="AutoPartsStore.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Добавить" Command="{Binding AddCommand}"/>
            <Button Content="Удалить" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
            <Button Content="Сохранить" Command="{Binding SaveCommand}"/>
            <Button Content="Экспорт Excel" Command="{Binding ExportExcelCommand}"/>
            <Button Content="Редактировать" Command="{Binding EditCommand}"/>
        </WrapPanel>

        <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" Padding="15" CornerRadius="8" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Фильтры" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <WrapPanel>
                    <TextBlock Text="Артикул:" VerticalAlignment="Center" Margin="5,0,2,0"/>
                    <TextBox Text="{Binding FilterArticle, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="5"/>

                    <TextBlock Text="Название:" VerticalAlignment="Center" Margin="5,0,2,0"/>
                    <TextBox Text="{Binding FilterName, UpdateSourceTrigger=PropertyChanged}" Width="180" Margin="5"/>

                    <TextBlock Text="Бренд:" VerticalAlignment="Center" Margin="5,0,2,0"/>
                    <ComboBox ItemsSource="{Binding Brands}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedBrand}" Width="140" Margin="5"/>

                    <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="5,0,2,0"/>
                    <ComboBox ItemsSource="{Binding Categories}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedCategory}" Width="140" Margin="5"/>

                    <TextBlock Text="Цена от:" VerticalAlignment="Center" Margin="5,0,2,0"/>
                    <TextBox Text="{Binding PriceFrom, UpdateSourceTrigger=PropertyChanged}" Width="90" Margin="5"/>

                    <TextBlock Text="до:" VerticalAlignment="Center" Margin="2,0,2,0"/>
                    <TextBox Text="{Binding PriceTo, UpdateSourceTrigger=PropertyChanged}" Width="90" Margin="5"/>

                    <CheckBox Content="Только в наличии" IsChecked="{Binding OnlyInStock}" Margin="15,5,5,5"/>
                    <Button Content="Применить" Command="{Binding FilterCommand}" Margin="5"/>
                    <Button Content="Сбросить" Command="{Binding ResetFilterCommand}" Margin="5"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="100"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Бренд" Binding="{Binding Brands.Name}" Width="120"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Categories.Name}" Width="120"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Остаток" Binding="{Binding StockQuantity}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <ProgressBar Grid.RowSpan="3" IsIndeterminate="{Binding IsBusy}" Width="150" Height="10"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
    </Grid>
</UserControl>