<Window x:Class="AutoPartsStore.Views.CreateStockReceivingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Поступление товара"
        Height="650"
        Width="850"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Выбор поставщика"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="Поставщик:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding Suppliers}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedSupplier}"
                              Width="300"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Добавление товара"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <WrapPanel VerticalAlignment="Center">

                    <TextBlock Text="Товар:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding Products}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedProduct}"
                              Width="250"/>

                    <TextBlock Text="Количество:"
                               VerticalAlignment="Center"
                               Margin="20,0,10,0"/>
                    <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                             Width="70"/>

                    <TextBlock Text="Цена закупки:"
                               VerticalAlignment="Center"
                               Margin="20,0,10,0"/>
                    <TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}"
                             Width="100"/>

                    <Button Content="Добавить"
                            Command="{Binding AddToCartCommand}"
                            Style="{StaticResource AccentButton}"
                            Margin="20,0,0,0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Состав поступления"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <DataGrid ItemsSource="{Binding Cart}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternatingRowBackground="#F5F7FA">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EEF2F5"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#D6EAF8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Товар"
                                            Binding="{Binding Product.Name}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Количество"
                                            Binding="{Binding Quantity}"
                                            Width="120"/>
                        <DataGridTextColumn Header="Цена"
                                            Binding="{Binding Price, StringFormat=N2}"
                                            Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Content="Сохранить поступление"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource AccentButton}"
                    Margin="5"/>

            <Button Content="Отмена"
                    Click="Close"
                    Style="{StaticResource DangerButton}"
                    Margin="5"/>

        </StackPanel>

    </Grid>
</Window>