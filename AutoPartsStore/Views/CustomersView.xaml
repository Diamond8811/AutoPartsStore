<UserControl x:Class="AutoPartsStore.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кнопки -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Добавить" Command="{Binding AddCommand}"/>
            <Button Content="Удалить" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
        </WrapPanel>

        <!-- Поиск -->
        <Border Grid.Row="1"
                Background="{StaticResource CardBackgroundBrush}"
                Padding="10"
                CornerRadius="8"
                Margin="0,0,0,10">
            <WrapPanel>
                <TextBlock Text="Поиск:"
                           VerticalAlignment="Center"
                           Margin="5"/>
                <TextBox Text="{Binding SearchText}"
                         Width="200"/>
                <Button Content="Найти"
                        Command="{Binding SearchCommand}"/>
            </WrapPanel>
        </Border>

        <!-- Таблица -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Customers}"
                  SelectedItem="{Binding SelectedCustomer}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО"
                                    Binding="{Binding FullName}"
                                    Width="200"/>
                <DataGridTextColumn Header="Телефон"
                                    Binding="{Binding Phone}"
                                    Width="150"/>
                <DataGridTextColumn Header="Email"
                                    Binding="{Binding Email}"
                                    Width="200"/>
                <DataGridTextColumn Header="Адрес"
                                    Binding="{Binding Address}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель редактирования -->
        <Border Grid.Row="3"
                Background="{StaticResource CardBackgroundBrush}"
                Padding="15"
                CornerRadius="8"
                Margin="0,10,0,0"
                Visibility="{Binding SelectedCustomer, Converter={StaticResource ObjectToVisibilityConverter}}">

            <StackPanel>

                <TextBlock Text="Редактирование клиента"
                           FontWeight="Bold"
                           FontSize="14"
                           Margin="0,0,0,10"/>

                <WrapPanel>

                    <TextBlock Text="ФИО:" VerticalAlignment="Center" Margin="5"/>
                    <TextBox Text="{Binding SelectedCustomer.FullName, UpdateSourceTrigger=PropertyChanged}"
                             Width="200"/>

                    <TextBlock Text="Телефон:" VerticalAlignment="Center" Margin="5"/>
                    <TextBox Text="{Binding SelectedCustomer.Phone, UpdateSourceTrigger=PropertyChanged}"
                             Width="150"/>

                    <TextBlock Text="Email:" VerticalAlignment="Center" Margin="5"/>
                    <TextBox Text="{Binding SelectedCustomer.Email, UpdateSourceTrigger=PropertyChanged}"
                             Width="200"/>

                    <TextBlock Text="Адрес:" VerticalAlignment="Center" Margin="5"/>
                    <TextBox Text="{Binding SelectedCustomer.Address, UpdateSourceTrigger=PropertyChanged}"
                             Width="250"/>

                </WrapPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">

                    <Button Content="Сохранить изменения"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource AccentButton}"/>

                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>