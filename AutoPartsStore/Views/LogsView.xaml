<UserControl x:Class="AutoPartsStore.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoPartsStore.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource CardBackgroundBrush}"
                Padding="15"
                CornerRadius="8"
                Margin="0,0,0,10">

            <WrapPanel VerticalAlignment="Center">

                <TextBlock Text="Пользователь:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox ItemsSource="{Binding Users}"
                          DisplayMemberPath="Login"
                          SelectedItem="{Binding SelectedUserFilter}"
                          Width="150"
                          Margin="5"/>

                <TextBlock Text="Тип действия:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox ItemsSource="{Binding ActionTypes}"
                          SelectedItem="{Binding SelectedActionType}"
                          Width="140"
                          Margin="5"/>

                <TextBlock Text="Дата с:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker SelectedDate="{Binding DateFrom}" Margin="5"/>

                <TextBlock Text="по:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker SelectedDate="{Binding DateTo}" Margin="5"/>

                <Button Content="Применить"
                        Command="{Binding RefreshCommand}"
                        Margin="5"/>

                <Button Content="Сбросить"
                        Command="{Binding ResetFiltersCommand}"
                        Margin="5"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Logs}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F9F9F9">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата"
                                    Binding="{Binding ActionDate, StringFormat=dd.MM.yyyy HH:mm}"
                                    Width="150"/>

                <DataGridTextColumn Header="Пользователь"
                                    Binding="{Binding Users.Login}"
                                    Width="120"/>

                <DataGridTextColumn Header="Действие"
                                    Binding="{Binding ActionType}"
                                    Width="100"/>

                <DataGridTextColumn Header="Таблица"
                                    Binding="{Binding TableName}"
                                    Width="120"/>

                <DataGridTextColumn Header="ID записи"
                                    Binding="{Binding RecordId}"
                                    Width="90"/>

                <DataGridTextColumn Header="Описание"
                                    Binding="{Binding Description}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
