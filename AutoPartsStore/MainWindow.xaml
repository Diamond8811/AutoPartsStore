<Window x:Class="AutoPartsStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoPartsStore"
        Height="800"
        Width="1300"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <Border DockPanel.Dock="Top"
                Background="{StaticResource PrimaryDarkBrush}"
                Padding="10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">

                    <Button Content="Главная"
                            Style="{StaticResource NavButton}"
                            Command="{Binding ShowDashboardCommand}"/>

                    <Button Content="Товары"
                            Style="{StaticResource NavButton}"
                            Command="{Binding ShowProductsCommand}"
                            Visibility="{Binding CanSeeProducts, Converter={StaticResource BoolToVisibility}}"/>

                    <Button Content="Заказы"
                            Style="{StaticResource NavButton}"
                            Command="{Binding ShowOrdersCommand}"
                            Visibility="{Binding CanSeeOrders, Converter={StaticResource BoolToVisibility}}"/>

                    <Button Content="Поступления"
                            Style="{StaticResource NavButton}"
                            Command="{Binding ShowStockCommand}"
                            Visibility="{Binding CanSeeStock, Converter={StaticResource BoolToVisibility}}"/>

                    <Button Content="Возвраты"
                            Style="{StaticResource NavButton}"
                            Command="{Binding ShowReturnsCommand}"
                            Visibility="{Binding CanSeeReturns, Converter={StaticResource BoolToVisibility}}"/>

                    <Button Content="Клиенты"
                            Style="{StaticResource NavButton}"
                            Command="{Binding ShowCustomersCommand}"
                            Visibility="{Binding CanSeeCustomers, Converter={StaticResource BoolToVisibility}}"/>

                    <Button Content="Поставщики"
                            Style="{StaticResource NavButton}"
                            Command="{Binding ShowSuppliersCommand}"
                            Visibility="{Binding CanSeeSuppliers, Converter={StaticResource BoolToVisibility}}"/>

                    <Button Content="Отчёты"
                            Style="{StaticResource NavButton}"
                            Command="{Binding ShowReportsCommand}"
                            Visibility="{Binding CanSeeReports, Converter={StaticResource BoolToVisibility}}"/>

                    <Button Content="Администрирование"
                            Style="{StaticResource NavButton}"
                            Command="{Binding ShowAdminCommand}"
                            Visibility="{Binding CanSeeAdmin, Converter={StaticResource BoolToVisibility}}"/>

                    <Button Content="Логи"
                            Style="{StaticResource NavButton}"
                            Command="{Binding ShowLogsCommand}"
                            Visibility="{Binding CanSeeLogs, Converter={StaticResource BoolToVisibility}}"/>

                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Grid.Column="1">

                    <TextBlock Text="{Binding CurrentUser.Login}"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="10,0"/>

                    <Button Content="Выйти"
                            Background="{StaticResource SecondaryBrush}"
                            Foreground="White"
                            Command="{Binding LogoutCommand}"
                            Padding="10,5"
                            Margin="10,0"/>
                </StackPanel>

            </Grid>
        </Border>

        <ContentControl Content="{Binding CurrentView}"/>

    </DockPanel>
</Window>